spring:
  config:
    activate:
      on-profile: uat
  datasource:
    url: ${APP_DB_URL_UAT}
    username: ${APP_DB_USER_UAT}
    password: ${APP_DB_PASSWORD_UAT}
  flyway:
    enabled: false

security:
  authorization:
    legacy-interceptor-enabled: false
  permission:
    legacy-endpoint-config-enabled: false
    cache-refresh-fixed-delay-ms: 600000
    method-security-allow-if-unmapped: true
    method-security-default-method: GET

jwt:
  secret: ${JWT_SECRET_UAT}

teams:
  webhook:
    url: ${TEAMS_WEBHOOK_UAT}

mail:
  access-key: ${MAIL_ACCESS_KEY_UAT}
  secret-key: ${MAIL_SECRET_KEY_UAT}
  from: ${MAIL_FROM_UAT}

logging:
  appender: PLAIN_CONSOLE

system:
  setting:
    cache:
      enabled: true
      ttl-seconds: 300
      max-entries: 512

notify:
  queue:
    scan:
      limit: 100
      fixed-delay-ms: 10000000
      max-retry: 5
      backoff-initial-delay-ms: 1000
      backoff-multiplier: 2.0
      backoff-max-delay-ms: 60000

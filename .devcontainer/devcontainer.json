{
  "name": "Kanto Sports Club Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "NODE_VERSION": "24.14.0",
      "MAVEN_VERSION": "3.9.9"
    }
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",

  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=kantosportsclub-maven-cache,target=/home/vscode/.m2/repository,type=volume",
    "source=kantosportsclub-npm-cache,target=/home/vscode/.npm,type=volume"
  ],

  "containerEnv": {
    "TZ": "Asia/Tokyo"
  },

  "remoteUser": "vscode",
  "postStartCommand": "if [ -S /var/run/docker.sock ]; then sock_gid=$(stat -c '%g' /var/run/docker.sock); sock_group=$(getent group \"$sock_gid\" | cut -d: -f1); if [ -n \"$sock_group\" ]; then sudo usermod -aG \"$sock_group\" vscode; fi; fi",
  "forwardPorts": [
    3000,
    3306,
    6379,
    8080,
    8081,
    8082,
    8083,
    8084,
    8888,
    9000,
    9001
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "al-rimi.tomcat",
        "avetis.tokyo-night",
        "bierner.markdown-mermaid",
        "dbaeumer.vscode-eslint",
        "dbcode.dbcode",
        "donjayamanne.githistory",
        "drewxs.tokyo-night-dark",
        "eamodio.gitlens",
        "editorconfig.editorconfig",
        "emmanuelbeziat.vscode-great-icons",
        "esbenp.prettier-vscode",
        "francescoanzalone.vsc-todo",
        "github.github-vscode-theme",
        "gruntfuggly.todo-tree",
        "jebbs.plantuml",
        "kevinrose.vsc-python-indent",
        "ms-azuretools.vscode-containers",
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-wsl",
        "ms-playwright.playwright",
        "openai.chatgpt",
        "pkief.material-icon-theme",
        "sonarsource.sonarlint-vscode",
        "redhat.vscode-yaml",
        "redhat.java",
        "sanaajani.taskrunnercode",
        "tal7aouy.icons",
        "vmware.vscode-boot-dev-pack",
        "vscode-icons-team.vscode-icons",
        "vscjava.vscode-java-pack",
        "vscjava.vscode-maven"
      ],
      "settings": {
        "java.configuration.updateBuildConfiguration": "interactive",
        "files.eol": "\n"
      }
    }
  }
}

{
  "name": "@kantosportsclub/api-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types worker-configuration.d.ts",
    "db:migration:create": "wrangler d1 migrations create kantosportsclub",
    "db:migrate:local": "wrangler d1 migrations apply kantosportsclub --local",
    "db:migrate:remote": "wrangler d1 migrations apply kantosportsclub --remote"
  },
  "dependencies": {
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "5.9.3",
    "wrangler": "^4.84.1"
  }
}

# Local all-in-one defaults

DB_HOST=mysql
DB_PORT=3306
DB_NAME=app
DB_USER=app
DB_PASSWORD=app

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=app-bucket

REDIS_HOST=redis
REDIS_PORT=6379

APPSERVER_URL=http://backend:8081
NEXT_PUBLIC_API_BASE_URL=http://backend:8081

# CSP tuning for frontend (keep 0 for normal dev; set 1 only for security scan)
CSP_DISABLE_UNSAFE_EVAL=0
CSP_DISABLE_UNSAFE_INLINE=0

# Instance 1: appserver + gateway (+ optional syncconnector)

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kantosportsclub
DB_USER=root
DB_PASSWORD=admin

MINIO_ENDPOINT=http://prod-minio.internal:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=app-bucket

REDIS_HOST=redis
REDIS_PORT=6379

# gateway -> appserver route
APPSERVER_URL=http://backend:8081

# CORS / login links exposed from gateway
FRONTEND_ORIGIN=http://localhost:8888
APP_LOGIN_URL=http://localhost:8888/login
TEAMS_WEBHOOK_URL=http://example.com/dummy-webhook-url

# optional syncconnector on instance1
SYNC_SIGNATURE_ENABLED=true
SYNC_SIGNATURE_SECRET=change-me-sync-secret
SYNC_SIGNED_REST_SECRET_KEY=change-me-sync-secret
SYNC_SIGNATURE_HEADER=X-Signature

# CSP tuning for frontend (keep 0 for normal dev; set 1 only for security scan)
CSP_DISABLE_UNSAFE_EVAL=0
CSP_DISABLE_UNSAFE_INLINE=0

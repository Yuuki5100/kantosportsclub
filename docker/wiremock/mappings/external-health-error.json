{
  "priority": 1,
  "request": {
    "method": "GET",
    "urlPath": "/external/health",
    "queryParameters": {
      "mode": {
        "equalTo": "error"
      }
    }
  },
  "response": {
    "status": 503,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "external-health-error.json",
    "fixedDelayMilliseconds": 300
  }
}

<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- ログ出力パス（必要に応じて外出し可能） -->
  <property name="LOG_PATH" value="${logging.file.path:logs/gateway}" />

  <!-- === JSON形式ログ（推奨） === -->
  <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
      <timeZone>Asia/Tokyo</timeZone>
    </encoder>
  </appender>

  <!-- === 開発用シンプルログ === -->
  <appender name="PLAIN_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- === ファイル出力（JSON）※必要であれば有効に === -->
  <!--
  <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/gateway.json</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/gateway.%d{yyyy-MM-dd}.json</fileNamePattern>
      <maxHistory>14</maxHistory>
    </rollingPolicy>
    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
      <timeZone>Asia/Tokyo</timeZone>
    </encoder>
  </appender>
  -->

  <!-- === 出力レベルとアペンダー切り替え === -->
  <root level="INFO">
    <!-- JSONログ推奨 -->
    <appender-ref ref="JSON_CONSOLE"/>
    
    <!-- ↓開発時はこっちでも可 -->
    <!-- <appender-ref ref="PLAIN_CONSOLE"/> -->
  </root>

</configuration>
